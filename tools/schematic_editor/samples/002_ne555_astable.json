    {"id":6,"type":"led","ref":"D1","x":120,"y":-40,"rotation":0,"flipH":false,"value":"RED","notes":"Output indicator"},
    {"id":7,"type":"resistor","ref":"R3","x":120,"y":-80,"rotation":90,"flipH":false,"value":"470Ω","notes":"LED current limiting resistor"},
    {"id":8,"type":"vcc","ref":"VCC1","x":0,"y":-120,"rotation":0,"flipH":false,"value":"+9V","notes":""},
    {"id":9,"type":"gnd","ref":"GND1","x":0,"y":120,"rotation":0,"flipH":false,"value":"","notes":""},
    {"id":10,"type":"cap_elec","ref":"C3","x":-180,"y":0,"rotation":90,"flipH":false,"value":"100µF","notes":"Supply bypass cap"}
  ],
