    {"id":7,"type":"cap_elec","ref":"C1","x":-140,"y":0,"rotation":0,"flipH":false,"value":"10µF","notes":"Input coupling cap"},
    {"id":8,"type":"cap_elec","ref":"C2","x":100,"y":-20,"rotation":0,"flipH":false,"value":"10µF","notes":"Output coupling cap"},
