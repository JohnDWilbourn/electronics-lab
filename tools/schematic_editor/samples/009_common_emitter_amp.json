    {"id":2,"type":"resistor","ref":"R1","x":-80,"y":-80,"rotation":90,"flipH":false,"value":"47kΩ","notes":"Bias divider — upper"},
    {"id":3,"type":"resistor","ref":"R2","x":-80,"y":40,"rotation":90,"flipH":false,"value":"10kΩ","notes":"Bias divider — lower"},
    {"id":4,"type":"resistor","ref":"RC","x":40,"y":-80,"rotation":90,"flipH":false,"value":"4.7kΩ","notes":"Collector load resistor"},
    {"id":5,"type":"resistor","ref":"RE","x":40,"y":60,"rotation":90,"flipH":false,"value":"1kΩ","notes":"Emitter resistor — stabilizes bias"},
